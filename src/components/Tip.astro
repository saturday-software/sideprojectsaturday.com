---
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<span class="tip" data-tip={text}>?</span>

<style>
  .tip {
    display: inline-block;
    position: relative;
    width: 14px;
    height: 14px;
    line-height: 14px;
    text-align: center;
    font-size: 10px;
    border: 1px solid #999;
    border-radius: 50%;
    color: #666;
    cursor: default;
    vertical-align: middle;
    top: -1px;
    margin-left: 3px;
  }

  .tip:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: #fff;
    font-size: 11px;
    padding: 4px 8px;
    white-space: nowrap;
    z-index: 10;
  }
</style>
