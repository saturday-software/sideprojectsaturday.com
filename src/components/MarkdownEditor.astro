---
interface Props {
  name: string;
  id?: string;
  label?: string;
}
const { name, id = 'editor', label } = Astro.props;
---

<div class="markdown-editor-wrapper" data-editor-id={id} data-label={label}>
  {label && (
    <div class="markdown-editor-header">
      <label for={id}>{label} <slot /></label>
      <button type="button" class="expand-btn" data-expand={id} aria-label="Expand">⤢</button>
    </div>
  )}
  <input type="hidden" id={`${id}-hidden`} name={name} />
  <div id={id} class="markdown-editor" data-hidden={`${id}-hidden`}></div>
</div>

<script>
  import { createMarkdownEditor } from '@/lib/markdown-editor';

  document.querySelectorAll<HTMLDivElement>('.markdown-editor').forEach((root) => {
    if (root.dataset.initialized) return;
    root.dataset.initialized = '1';
    const hidden = document.getElementById(root.dataset.hidden!) as HTMLInputElement;
    if (hidden) createMarkdownEditor(root, hidden);
  });

  document.querySelectorAll<HTMLButtonElement>('.expand-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const editorId = btn.dataset.expand!;
      const wrapper = btn.closest('.markdown-editor-wrapper')!;
      const pane = wrapper.closest('.window-pane')!;
      const isExpanded = wrapper.classList.contains('expanded');

      // Collect all elements between the wrapper and the pane
      function hideOthers(el: Element) {
        const parent = el.parentElement!;
        Array.from(parent.children).forEach((sibling) => {
          if (sibling !== el) {
            (sibling as HTMLElement).dataset.hiddenByExpand = '1';
            (sibling as HTMLElement).style.display = 'none';
          }
        });
        if (parent !== pane) hideOthers(parent);
      }

      function showOthers() {
        pane.querySelectorAll('[data-hidden-by-expand]').forEach((el) => {
          (el as HTMLElement).style.display = '';
          delete (el as HTMLElement).dataset.hiddenByExpand;
        });
      }

      const editorEl = document.getElementById(editorId) as any;

      if (!isExpanded) {
        hideOthers(wrapper);
        wrapper.classList.add('expanded');
        btn.textContent = '⤡';
        editorEl?.__setMinLines?.(13);
      } else {
        showOthers();
        wrapper.classList.remove('expanded');
        btn.textContent = '⤢';
        editorEl?.__setMinLines?.(3);
      }

      // Focus the editor
      const editor = document.getElementById(editorId);
      const cmContent = editor?.querySelector('.cm-content') as HTMLElement;
      cmContent?.focus();
    });
  });
</script>

<style is:global>
  .markdown-editor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .markdown-editor-header label {
    margin-bottom: 3px;
  }

  .expand-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: "Departure Mono", monospace;
    font-size: 18px;
    line-height: 1;
    color: #000;
    width: 22px;
    height: 22px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .expand-btn:hover {
    background: #000;
    color: #fff;
  }

  .markdown-editor-wrapper.expanded {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .markdown-editor-wrapper.expanded .markdown-editor-header {
    display: flex;
  }

  .markdown-editor-wrapper.expanded .markdown-editor {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .markdown-editor-wrapper.expanded .markdown-editor .cm-editor {
    flex: 1;
    display: flex;
    flex-direction: column;
    margin-bottom: 0;
  }

  .markdown-editor-wrapper.expanded .markdown-editor .cm-scroller {
    flex: 1;
  }

  .expanded ~ *, .expanded + * {
    display: none;
  }

  .window:has(.expanded) .window-pane {
    display: flex;
    flex-direction: column;
    min-height: 300px;
  }

  .markdown-editor .cm-editor {
    font-family: "Departure Mono", monospace;
    font-size: 12px;
    border: 1px solid #000;
    background: #fff;
    margin-bottom: 8px;
  }

  .markdown-editor .cm-editor.cm-focused {
    outline: none;
  }

  .markdown-editor .cm-scroller {
    font-family: "Departure Mono", monospace;
  }

  .markdown-editor .cm-content {
    font-family: "Departure Mono", monospace;
    font-size: 12px;
    padding: 4px 2px;
  }

  .markdown-editor .cm-gutters {
    display: none;
  }

  .markdown-editor .cm-activeLine,
  .markdown-editor .cm-activeLineGutter {
    background: none !important;
  }

  .markdown-editor .cm-line * {
    text-decoration: none !important;
  }

  .markdown-editor a.cm-collapsed-link {
    text-decoration: underline !important;
    color: #0066cc;
    cursor: text;
  }

  .markdown-editor.shift-held a.cm-collapsed-link {
    cursor: pointer;
  }

  .markdown-editor .cm-md-bold {
    font-weight: bold;
  }

  .markdown-editor .cm-md-italic {
    font-style: italic;
  }

  .markdown-editor .cm-editor.cm-drag-over {
    outline: 2px dashed #999;
    outline-offset: -2px;
  }

  .cm-image-widget {
    max-width: 100%;
    margin: 8px 0;
    display: flex;
    justify-content: center;
  }

  .cm-image-inner {
    position: relative;
    display: inline-block;
    max-width: 100%;
  }

  .cm-image-widget img {
    max-width: 100%;
    display: block;
  }

  .cm-resize-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 6px;
    border-radius: 3px;
    cursor: col-resize;
    opacity: 0;
    transition: opacity 0.15s;
    background: #000;
    z-index: 1;
  }

  .cm-image-inner:hover .cm-resize-handle {
    opacity: 0.3;
  }

  .cm-resize-handle:hover {
    opacity: 0.6 !important;
  }

  .cm-resize-left {
    left: 0;
  }

  .cm-resize-right {
    right: 0;
  }
</style>
