---
import Layout from "../layouts/Layout.astro";

const message = Astro.url.searchParams.get("message");
const error = Astro.url.searchParams.get("error");
---

<Layout>
  <h1>Side Project Saturday</h1>
  <p>A small, local weekly meetup to focus on side projects and share demos.</p>

  {message && <div class="message success">{message}</div>}
  {error && <div class="message error">{error}</div>}

  <form method="POST" action="/api/subscribe" style="margin-top: 24px;">
    <label for="email">Get weekly updates</label>
    <div style="display: flex; gap: 8px;">
      <input type="email" id="email" name="email" placeholder="your@email.com" required />
      <button type="submit">Subscribe</button>
    </div>
  </form>
</Layout>
