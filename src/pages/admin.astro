---
import Layout from "@/layouts/Layout.astro";
import { isAdmin } from "@/lib/auth";
import { getUpcomingSaturdays, dateKeyToSlug } from "@/lib/dates";
import { generateShareCode } from "@/lib/share";
import { getSubscriberCount } from "@/lib/subscribers";
import { env } from "cloudflare:workers";
import type { EventDO } from "@/do/EventDO";
const authenticated = isAdmin(Astro.request);

const WEEKS_AHEAD = 4;

let events: { date: string; cancelled: boolean }[] = [];
let shareCode = "";
let subscriberCount = { total: 0, verified: 0 };

if (authenticated) {
  const saturdays = getUpcomingSaturdays(WEEKS_AHEAD);

  for (const date of saturdays) {
    const slug = dateKeyToSlug(date);
    const id = env.EVENT_DO.idFromName(slug);
    const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;
    await stub.init(slug);
    events.push({ date, cancelled: await stub.isCancelled() });
  }

  const nextActive = events.find((e) => !e.cancelled)?.date ?? saturdays[0];
  shareCode = await generateShareCode(env.SHARE_SEED, nextActive);
  subscriberCount = await getSubscriberCount(env.DB);
}

const message = Astro.url.searchParams.get("message");
---

<Layout title="Admin — Side Project Saturday" windowTitle="Admin">
  {!authenticated ? (
    <div>
      <h1>Login</h1>
      <form method="POST" action="/api/admin/login">
        <label for="password">password</label>
        <input type="password" id="password" name="password" required />
        <button type="submit" class="btn">Log in</button>
      </form>
    </div>
  ) : (
    <div>
      <h1>Admin</h1>

      {message && <div class="message success">{message}</div>}

      <section style="margin-bottom: 20px;">
        <h2>Upcoming Events</h2>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          {events.map((event) => (
            <form method="POST" action="/api/admin/cancel">
              <input type="hidden" name="date" value={event.date} />
              <button
                type="submit"
                class:list={["btn", "event-toggle", { cancelled: event.cancelled }]}
                data-tip={event.cancelled ? "Uncancel" : "Cancel"}
              >
                {event.date}
              </button>
            </form>
          ))}
        </div>
      </section>

      <hr />

      <section style="margin-bottom: 20px;">
        <h2>Add event image</h2>
        <form method="POST" action="/api/admin/upload-image" enctype="multipart/form-data">
          <input type="hidden" name="date" value={events[0]?.date} />
          <input type="file" name="image" accept="image/*" required />
          <button type="submit" class="btn">Upload</button>
        </form>
      </section>

      <hr />

      <section style="margin-bottom: 20px;">
        <h2>Subscribers</h2>
        <p>total: {subscriberCount.total} / verified: {subscriberCount.verified}</p>
      </section>

      <hr />

      <section>
        <h2>Links</h2>
        <p style="margin-bottom: 4px;"><a href={`/share/${shareCode}`}>share page →</a></p>
        <p style="margin-bottom: 4px;"><a href={`/share/${shareCode}/qr`}>share QR code →</a></p>
        <p style="margin-bottom: 0;"><a href={`/events/${dateKeyToSlug(events[0]?.date)}`}>event page →</a></p>
      </section>
    </div>
  )}
</Layout>

<style>
  .event-toggle {
    position: relative;
    padding: 6px 12px;
    border: 2px solid #000;
    background: #000;
    color: #fff;
    border-radius: 4px;
  }

  .event-toggle:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: #fff;
    font-size: 11px;
    padding: 4px 8px;
    white-space: nowrap;
    z-index: 10;
  }

  .event-toggle:hover {
    background: #ff0;
    color: #000;
  }

  .event-toggle:active {
    background: #f00;
    color: #fff;
  }

  .event-toggle.cancelled {
    background: #fff;
    color: #000;
    text-decoration: line-through;
  }

  .event-toggle.cancelled:hover {
    background: #ff0;
    color: #000;
  }

  .event-toggle.cancelled:active {
    background: #0a0;
    color: #fff;
  }
</style>
