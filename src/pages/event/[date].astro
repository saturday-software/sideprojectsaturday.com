---
import Layout from "../../layouts/Layout.astro";
import { formatEventDate, isSubmissionOpen } from "../../lib/dates";
import type { EventDO } from "../../do/EventDO";

const { date } = Astro.params;
if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return Astro.redirect("/");
}

const env = Astro.locals.runtime.env;
const id = env.EVENT_DO.idFromName(date);
const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;
await stub.init(date);

const cancelled = await stub.isCancelled();
const open = isSubmissionOpen(date);
const eventDate = formatEventDate(date);

const message = Astro.url.searchParams.get("message");
const error = Astro.url.searchParams.get("error");
---

<Layout title={`${eventDate} — Side Project Saturday`}>
  <h1>Side Project Saturday</h1>
  <p><strong>{eventDate}</strong></p>

  {cancelled && (
    <div class="message error">This event has been cancelled.</div>
  )}

  {message && <div class="message success">{message}</div>}
  {error && <div class="message error">{error}</div>}

  {!cancelled && open ? (
    <div>
      <h2>Submit Your Project</h2>
      <p>Share what you'll be working on or demoing this Saturday.</p>

      <form method="POST" action={`/api/event/${date}/submit`}>
        <label for="project_name">Project Name *</label>
        <input type="text" id="project_name" name="project_name" required />

        <label for="description">Description *</label>
        <textarea id="description" name="description" rows="3" required></textarea>

        <label for="participant_name">Your Name *</label>
        <input type="text" id="participant_name" name="participant_name" required />

        <label for="email">Email * <span style="font-weight: normal; color: #666;">(links you to the participant list)</span></label>
        <input type="email" id="email" name="email" required />

        <label for="contact_info">Contact Info / Blurb <span style="font-weight: normal; color: #666;">(shared with participants)</span></label>
        <input type="text" id="contact_info" name="contact_info" />

        <label for="private_details">Private Details <span style="font-weight: normal; color: #666;">(participants only)</span></label>
        <textarea id="private_details" name="private_details" rows="2"></textarea>

        <button type="submit" style="margin-top: 8px;">Submit Project</button>
      </form>
    </div>
  ) : !cancelled ? (
    <p>Submissions for this event are closed.</p>
  ) : null}

  <p style="margin-top: 32px;"><a href="/">← Back home</a></p>
</Layout>
