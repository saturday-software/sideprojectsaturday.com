---
import Layout from "../../layouts/Layout.astro";
import MarkdownEditor from "../../components/MarkdownEditor.astro";
import Tip from "../../components/Tip.astro";
import { isSubmissionOpen } from "../../lib/dates";
import { env } from "cloudflare:workers";
import type { EventDO } from "../../do/EventDO";

const { date } = Astro.params;
if (!date || !/^\d{4}-\d{2}-\d{2}$/.test(date)) {
  return Astro.redirect("/");
}
const id = env.EVENT_DO.idFromName(date);
const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;
await stub.init(date);

const cancelled = await stub.isCancelled();
const open = isSubmissionOpen(date);
const eventDate = date;

const message = Astro.url.searchParams.get("message");
const error = Astro.url.searchParams.get("error");
---

<Layout
  title={`${eventDate} — Side Project Saturday`}
  windowTitle="Side Project Saturday"
>
  <p class="event-date">{eventDate}</p>

  {cancelled && <div class="message error">This event has been cancelled.</div>}

  {message && <div class="message success">{message}</div>}
  {error && <div class="message error">{error}</div>}

  {
    !cancelled && open ? (
      <div>
        <p>Share your work with the community.</p>

        <form method="POST" action={`/api/event/${date}/submit`}>
          <div class="form-row">
            <div class="form-field">
              <label for="participant_name">
                name<span class="req">*</span>{" "}
                <Tip text="Will be listed on the site, pseudonyms ok" />
              </label>
              <input
                type="text"
                id="participant_name"
                name="participant_name"
                required
                autocomplete="off"
                data-1p-ignore
                placeholder="Sally G."
              />
            </div>
            <div class="form-field">
              <label for="email">
                email<span class="req">*</span>{" "}
                <Tip text="Use the same email you signed up with, not shared publicly" />
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="off"
                data-1p-ignore
                placeholder="sally@email.com"
              />
            </div>
          </div>

          <MarkdownEditor
            id="project_summary"
            name="description"
            label="project summary"
          >
            <Tip text="Shared publicly on the recap page. Leave empty to opt out. Markdown is supported." />
          </MarkdownEditor>

          <MarkdownEditor
            id="private_details"
            name="private_details"
            label="note for attendees"
          >
            <Tip text="Will only be shared with other attendees in the recap email. Markdown is supported." />
          </MarkdownEditor>

          <button type="submit" class="btn" style="margin-top: 6px;">
            Submit
          </button>
        </form>
      </div>
    ) : !cancelled ? (
      <p>Submissions for this event are closed.</p>
    ) : null
  }

  <a href="/" class="back-link">← back</a>
</Layout>

<style>
  .req {
    color: #999;
  }

  .event-date {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
    margin: -8px 0 12px;
  }

  .form-row {
    display: flex;
    gap: 12px;
  }

  .form-field {
    flex: 1;
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
