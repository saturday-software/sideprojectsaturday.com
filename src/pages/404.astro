---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="404 — Side Project Saturday" windowTitle="Error">
  <div class="not-found">
    <pre class="ascii-art">{`
  ___  ___  ___
 / _ |/ _ \\/ _ |
/ __ / // / __ |
\\___/\\___/\\___/
    `}</pre>
    <h1>Page Not Found</h1>
    <p>Looks like this page took a Saturday off.</p>
    <p class="hint">Maybe it's working on a side project somewhere...</p>
    <a href="/" class="btn home-btn">← Take me home</a>
  </div>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: 8px 0;
  }

  .ascii-art {
    font-size: 14px;
    line-height: 1.2;
    margin: 0 0 8px;
    letter-spacing: 0.05em;
  }

  .not-found h1 {
    font-size: 16px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .not-found p {
    font-size: 13px;
    margin-bottom: 8px;
  }

  .hint {
    color: #666;
    font-size: 11px !important;
    font-style: italic;
  }

  .home-btn {
    display: inline-block;
    margin-top: 16px;
    padding: 6px 16px;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    font-size: 12px;
    text-decoration: none;
  }

  .home-btn:hover {
    background: #ff0;
  }

  .home-btn:active {
    background: #000;
    color: #fff;
  }
</style>
