---
import Layout from "../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { unsubscribe } from "../lib/subscribers";

const email = Astro.url.searchParams.get("email");
let success = false;

if (email) {
  const db = env.DB;
  success = await unsubscribe(db, decodeURIComponent(email));
}
---

<Layout title="Unsubscribe — Side Project Saturday" windowTitle="Unsubscribe">
  {success ? (
    <div>
      <h1>Unsubscribed</h1>
      <p>You've been removed from the list. See you around.</p>
    </div>
  ) : (
    <div>
      <h1>Something went wrong</h1>
      <p>Couldn't process that. The email may not be in our system.</p>
    </div>
  )}
</Layout>
