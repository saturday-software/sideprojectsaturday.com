---
import Layout from "@/layouts/Layout.astro";
import { getCurrentSaturday, slugToDateKey, formatEventDate } from "@/lib/dates";
import { listPastEvents, eventImageKey } from "@/lib/events";
import { env } from "cloudflare:workers";
import type { EventDO } from "@/do/EventDO";

const today = getCurrentSaturday();
const rows = await listPastEvents(env.DB, today);

const pastEvents: { date: string; slug: string; submissions: number; hasImage: boolean }[] = [];

for (const row of rows) {
  if (row.cancelled) continue;

  const slug = String(row.date);
  const id = env.EVENT_DO.idFromName(slug);
  const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;

  const submissions = await stub.getPublicSubmissions();
  if (submissions.length === 0) continue;

  const hasImage = await env.IMAGES_BUCKET.head(eventImageKey(slug)) !== null;
  pastEvents.push({ date: slugToDateKey(slug), slug, submissions: submissions.length, hasImage });
}
---

<Layout title="Past Events — Side Project Saturday" windowTitle="Past Events">
  <h1>Past Events</h1>

  {pastEvents.length > 0 ? (
    <div>
      {pastEvents.map((event) => (
        <a href={`/events/${event.slug}`} class="event-link">
          {event.hasImage && (
            <img
              src={`/api/image/${eventImageKey(event.slug)}`}
              alt={`Event photo for ${formatEventDate(event.date)}`}
              class="event-thumb"
            />
          )}
          <div>
            <p class="event-date">{formatEventDate(event.date)}</p>
            <p class="event-meta">{event.submissions} project{event.submissions !== 1 ? "s" : ""}</p>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <p>No past events yet.</p>
  )}

  <a href="/" class="back-link">← back</a>
</Layout>

<style>
  .event-link {
    display: block;
    padding: 12px;
    margin-bottom: 10px;
    border: 1px solid #000;
    background: #fff;
    text-decoration: none;
    color: inherit;
  }

  .event-link:hover {
    background: #ff0;
  }

  .event-thumb {
    width: 100%;
    border: 1px solid #000;
    margin-bottom: 8px;
  }

  .event-date {
    margin-bottom: 2px;
    font-weight: bold;
  }

  .event-meta {
    margin-bottom: 0;
    color: #666;
    font-size: 11px;
  }
</style>
