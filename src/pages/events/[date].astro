---
import Layout from "@/layouts/Layout.astro";
import { actions } from "astro:actions";
import { formatEventDate, slugToDateKey, isSaturday, todayDateKey } from "@/lib/dates";
import { eventImageKey } from "@/lib/events";
import { renderMarkdown } from "@/lib/render-markdown";
import { isAdmin } from "@/lib/auth";
import { env } from "cloudflare:workers";
import type { EventDO } from "@/do/EventDO";

const { date: slug } = Astro.params;
if (!slug || !/^\d{6}$/.test(slug)) {
  return new Response(null, { status: 404 });
}
const date = slugToDateKey(slug);

// Check if the date is a Saturday
if (!isSaturday(date)) {
  return new Response(null, { status: 404 });
}

// Check if the event is in the future
const isFuture = date > todayDateKey();

const id = env.EVENT_DO.idFromName(slug);
const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;

const submissions = isFuture ? [] : await stub.getPublicSubmissions();
const imageKey = eventImageKey(slug);
const hasImage = isFuture ? false : await env.IMAGES_BUCKET.head(imageKey) !== null;
const eventDate = formatEventDate(date);
const authenticated = isAdmin(Astro.request);

const uploadResult = Astro.getActionResult(actions.events.uploadImage);
const message = uploadResult?.data?.message;
const error = uploadResult?.error?.message;
---

<Layout title={`Event: ${eventDate} — Side Project Saturday`} windowTitle="Side Project Saturday">
  <h1>Event</h1>
  <p>{eventDate}</p>

  {message && <div class="message success">{message}</div>}
  {error && <div class="message error">{error}</div>}

  {hasImage && (
    <img
      src={`/api/image/${imageKey}`}
      alt="Event photo"
      style="width: 100%; border: 1px solid #000; margin-bottom: 16px;"
    />
  )}

  {authenticated && (
    <form method="POST" action={actions.events.uploadImage} enctype="multipart/form-data" style="margin-bottom: 16px;">
      <input type="hidden" name="slug" value={slug} />
      <input type="file" name="image" accept="image/*" required />
      <button type="submit" class="btn">Upload image</button>
    </form>
  )}

  {isFuture ? (
    <p>This event hasn't happened yet! Check back after {eventDate} to see what people built.</p>
  ) : submissions.length > 0 ? (
    <div>
      {submissions.map((s) => (
        <div class="project-card">
          <h2 style="text-transform: none; letter-spacing: normal;">{s.participant_name}</h2>
          <p style="margin-bottom: 0;" set:html={renderMarkdown(s.description)} />
        </div>
      ))}
    </div>
  ) : (
    <p>No projects were submitted for this event.</p>
  )}

  <a href="/" class="back-link">← back</a>
</Layout>

<style>
  .project-card {
    padding: 12px;
    margin-bottom: 10px;
    border: 1px solid #000;
    background: #fff;
  }
</style>
