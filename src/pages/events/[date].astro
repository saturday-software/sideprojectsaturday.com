---
import Layout from "@/layouts/Layout.astro";
import Tip from "@/components/Tip.astro";
import { actions } from "astro:actions";
import { formatEventDate, slugToDateKey, isSaturday, todayDateKey } from "@/lib/dates";
import { eventImageKey } from "@/lib/events";
import { renderMarkdown } from "@/lib/render-markdown";
import { isAdmin } from "@/lib/auth";
import { env } from "cloudflare:workers";
import type { EventDO } from "@/do/EventDO";

const { date: slug } = Astro.params;
if (!slug || !/^\d{6}$/.test(slug)) {
  return new Response(null, { status: 404 });
}
const date = slugToDateKey(slug);

// Check if the date is a Saturday
if (!isSaturday(date)) {
  return new Response(null, { status: 404 });
}

// Check if the event is in the future
const isFuture = date > todayDateKey();

const id = env.EVENT_DO.idFromName(slug);
const stub = env.EVENT_DO.get(id) as DurableObjectStub<EventDO>;

const submissions = isFuture ? [] : await stub.getPublicSubmissions();
const projects = submissions.filter((s) => s.description.trim() !== "");
const imageKey = eventImageKey(slug);
const hasImage = isFuture ? false : await env.IMAGES_BUCKET.head(imageKey) !== null;
const eventDate = formatEventDate(date);
const authenticated = isAdmin(Astro.request);

const uploadResult = Astro.getActionResult(actions.events.uploadImage);
const deleteResult = Astro.getActionResult(actions.events.deleteSubmission);
const message = uploadResult?.data?.message ?? deleteResult?.data?.message;
const error = uploadResult?.error?.message ?? deleteResult?.error?.message;
---

<Layout title={`Event: ${eventDate} — Side Project Saturday`} windowTitle="Side Project Saturday">
  <h1>Event</h1>
  <p>{eventDate}</p>

  {message && <div class="message success">{message}</div>}
  {error && <div class="message error">{error}</div>}

  {hasImage && (
    <img
      src={`/api/image/${imageKey}`}
      alt="Event photo"
      style="width: 100%; border: 1px solid #000; margin-bottom: 16px;"
    />
  )}

  {authenticated && (
    <form method="POST" action={actions.events.uploadImage} enctype="multipart/form-data" style="margin-bottom: 16px;">
      <input type="hidden" name="slug" value={slug} />
      <input type="file" name="image" accept="image/*" required />
      <button type="submit" class="btn">Upload image</button>
    </form>
  )}

  {isFuture ? (
    <p>This event hasn't happened yet! Check back after {eventDate} to see what people built.</p>
  ) : submissions.length > 0 ? (
    <div>
      <h2 class="section-heading">
        Participants
        <Tip text="Only includes folks who chose to share they were here." />
      </h2>
      <ul class="participant-list">
        {submissions.map((s) => (
          <li>
            <span>{s.participant_name}</span>
            {authenticated && (
              <form method="POST" action={actions.events.deleteSubmission} class="delete-form">
                <input type="hidden" name="slug" value={slug} />
                <input type="hidden" name="id" value={s.id} />
                <button type="submit" class="delete-btn" title="Delete submission" onclick={`return confirm('Delete submission from ${s.participant_name}?')`}>
                  <img src="https://api.iconify.design/pixelarticons/trash.svg" alt="Delete" width="14" height="14" />
                </button>
              </form>
            )}
          </li>
        ))}
      </ul>

      {projects.length > 0 && (
        <>
          <h2 class="section-heading">Projects</h2>
          {projects.map((s) => (
            <div class="project-card">
              <h3 class="project-name">{s.participant_name}</h3>
              <p style="margin-bottom: 0;" set:html={renderMarkdown(s.description)} />
            </div>
          ))}
        </>
      )}
    </div>
  ) : (
    <p>No one shared their attendance for this event.</p>
  )}

  <a href="/" class="back-link">← back</a>
</Layout>

<style>
  .section-heading {
    text-transform: none;
    letter-spacing: normal;
    font-size: 16px;
    margin-top: 16px;
    margin-bottom: 8px;
  }

  .participant-list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    border: 1px solid #000;
    background: #fff;
  }

  .participant-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 10px;
    border-bottom: 1px solid #ccc;
  }

  .participant-list li:last-child {
    border-bottom: none;
  }

  .delete-form {
    margin: 0;
  }

  .delete-btn {
    background: none;
    border: none;
    padding: 2px;
    cursor: pointer;
    opacity: 0.4;
    display: flex;
    align-items: center;
  }

  .delete-btn:hover,
  .delete-btn:active {
    opacity: 1;
    background: none;
  }

  .project-card {
    padding: 12px;
    margin-bottom: 10px;
    border: 1px solid #000;
    background: #fff;
  }

  .project-name {
    text-transform: none;
    letter-spacing: normal;
    font-size: 15px;
    margin: 0 0 6px;
  }
</style>
