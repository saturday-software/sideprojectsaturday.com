---
interface Props {
  title?: string;
  windowTitle?: string;
  subtitle?: string;
  supertitle?: string;
}
const { title = "Side Project Saturday", windowTitle = "Side Project Saturday", subtitle, supertitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://unpkg.com/@sakun/system.css" />
    <meta name="description" content="Every Saturday. Build stuff. Show it off. A weekly side project meetup in Brooklyn." />
    <title>{title}</title>
  </head>
  <body>
    <main>
      {supertitle && (
        <p class="window-supertitle">{supertitle}</p>
      )}
      <div class="window">
        <div class="title-bar">
          <h1 class="title">{windowTitle}</h1>
        </div>
        <div class="separator"></div>
        <div class="window-pane">
          <slot />
        </div>
      </div>
      {subtitle && (
        <p class="window-subtitle">{subtitle}</p>
      )}
      <slot name="after" />
    </main>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Departure Mono";
    src:
      url("/DepartureMono-Regular.woff2") format("woff2"),
      url("/DepartureMono-Regular.woff") format("woff");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  * {
    box-sizing: border-box;
    font-family: "Departure Mono", monospace;
  }

  html {
    background: #c0c0c0;
  }

  body {
    font-family: "Departure Mono", monospace;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 48px 16px;
  }

  main {
    max-width: 560px;
    width: 100%;
  }

  .window {
    font-family: "Departure Mono", monospace;
    overflow: visible;
  }

  .window .title-bar .title {
    font-family: "Departure Mono", monospace;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: -0.02em;
  }

  .window-pane {
    padding: 20px;
    font-size: 13px;
    line-height: 1.6;
    overflow: visible;
  }

  h1, h2, h3 {
    font-family: "Departure Mono", monospace;
    font-weight: normal;
  }

  h1 {
    font-size: 18px;
    margin-bottom: 8px;
  }

  h2 {
    font-size: 14px;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  p {
    margin-bottom: 12px;
    line-height: 1.6;
  }

  a {
    color: #000;
  }

  input[type="text"],
  input[type="email"],
  input[type="password"],
  textarea {
    font-family: "Departure Mono", monospace;
    font-size: 12px;
    padding: 4px 6px;
    border: 1px solid #000;
    background: #fff;
    width: 100%;
    margin-bottom: 8px;
    border-radius: 0;
    outline: none;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  input[type="password"]:focus,
  textarea:focus {
    background: #fff;
    color: #000;
  }

  input[type="file"] {
    font-family: "Departure Mono", monospace;
    font-size: 11px;
    margin-bottom: 8px;
  }

  textarea {
    resize: vertical;
  }

  button, .btn {
    font-family: "Departure Mono", monospace;
    font-size: 12px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  button:active, .btn:active {
    font-family: "Departure Mono", monospace;
    background: #000;
    color: #fff;
  }

  label {
    display: block;
    font-size: 12px;
    margin-bottom: 3px;
  }

  .message {
    padding: 8px 10px;
    margin-bottom: 12px;
    font-size: 12px;
    border: 2px solid #000;
  }

  .message.success {
    background: #fff;
    color: #000;
  }

  .message.success::before {
    content: "✓ ";
  }

  .message.error {
    background: #fff;
    color: #000;
  }

  .message.error::before {
    content: "✕ ";
  }

  hr {
    border: none;
    border-top: 1px solid #000;
    margin: 16px 0;
  }

  .back-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 12px;
  }

  .window-supertitle {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 8px;
    color: #666;
  }

  .window-subtitle {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 12px auto 0;
    color: #fff;
    background: #000;
    padding: 6px 16px;
    width: fit-content;
  }

  .after-window {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin: 12px 1rem 0;
  }

  .next-event-badge {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: #000;
    color: #fff;
    padding: 4px 8px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .attribution {
    text-align: right;
    font-size: 11px;
    letter-spacing: 0.08em;
    margin: 0;
    color: #666;
    min-width: 0;
  }

  @media (max-width: 480px) {
    body {
      padding: 16px 8px;
    }

    .window-pane {
      padding: 14px;
    }
  }
</style>
